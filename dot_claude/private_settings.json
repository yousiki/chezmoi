{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f $HOME/.claude/hooks/rtk-rewrite.sh ] && $HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Read|Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/nono-hook.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      },
      "autoUpdate": true
    },
    "yousiki-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "yousiki/claude-plugins"
      },
      "autoUpdate": true
    }
  },
  "language": "简体中文",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
