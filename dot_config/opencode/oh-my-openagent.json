{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "kimi-for-coding/k2p5",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        },
        "zai-coding-plan/glm-5",
        "zhipuai-coding-plan/glm-5.1",
        "xiaomi/mimo-v2-pro",
        "opencode/big-pickle"
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "librarian": {
      "model": "zai-coding-plan/glm-4.7",
      "fallback_models": [
        "zhipuai-coding-plan/glm-4.7",
        "zai-coding-plan/glm-5-turbo",
        "zhipuai-coding-plan/glm-5-turbo",
        "openai/gpt-5.4-mini"
      ]
    },
    "explore": {
      "model": "opencode/gpt-5-nano",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "zai-coding-plan/glm-5.1",
        "zhipuai-coding-plan/glm-5.1"
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": ["zai-coding-plan/glm-4.6v", "openai/gpt-5-nano"]
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "kimi-for-coding/k2p5",
        "zai-coding-plan/glm-5.1",
        "zhipuai-coding-plan/glm-5.1",
        "xiaomi/mimo-v2-pro"
      ]
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "zai-coding-plan/glm-5",
      "fallback_models": [
        "zhipuai-coding-plan/glm-5",
        "kimi-for-coding/k2p5",
        "zai-coding-plan/glm-5.1",
        "zhipuai-coding-plan/glm-5.1"
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "writing": {
      "model": "opencode/gpt-5-nano",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "zai-coding-plan/glm-5-turbo",
        "zhipuai-coding-plan/glm-5-turbo"
      ]
    }
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  }
}
