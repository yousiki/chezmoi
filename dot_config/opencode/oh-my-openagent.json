  "hashline_edit": true,
  "model_fallback": true,
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "session"
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "runtime_fallback": true,
  "claude_code": {
    "mcp": false,
    "commands": false,
    "skills": false,
    "agents": false,
    "hooks": false,
    "plugins": false
  },
  "experimental": {
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "detailed",
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "lsp_rename",
        "session_read",
        "session_write",
        "session_search"
      ]
    }
  },
  "_migrations": ["model-version:openai/gpt-5.3-codex->openai/gpt-5.4"]
}
