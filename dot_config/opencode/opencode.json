{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "prettier": {
      "command": [
        "bunx",
        "--package",
        "prettier",
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".html",
        ".css",
        ".scss",
        ".less",
        ".md",
        ".mdx",
        ".json",
        ".jsonc",
        ".yaml",
        ".yml",
        ".vue"
      ]
    },
    "biome": {
      "command": [
        "bunx",
        "--package",
        "@biomejs/biome",
        "biome",
        "format",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts"
      ]
    },
    "oxfmt": {
      "disabled": true,
      "command": [
        "bunx",
        "--package",
        "oxfmt",
        "oxfmt",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx"
      ]
    },
    "ruff": {
      "command": [
        "uvx",
        "--from",
        "ruff",
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "uv": {
      "disabled": true
    }
  },
  "lsp": {
    "bash": {
      "command": [
        "bunx",
        "--package",
        "bash-language-server",
        "bash-language-server",
        "start"
      ]
    },
    "yaml-ls": {
      "command": [
        "bunx",
        "--package",
        "yaml-language-server",
        "yaml-language-server",
        "--stdio"
      ]
    },
    "typescript": {
      "command": [
        "bunx",
        "--package",
        "typescript",
        "--package",
        "typescript-language-server",
        "typescript-language-server",
        "--stdio"
      ]
    },
    "eslint": {
      "command": [
        "bunx",
        "--package",
        "vscode-langservers-extracted",
        "vscode-eslint-language-server",
        "--stdio"
      ]
    },
    "oxlint": {
      "command": [
        "bunx",
        "--package",
        "oxlint",
        "oxlint",
        "--lsp"
      ]
    },
    "vue": {
      "command": [
        "bunx",
        "--package",
        "typescript",
        "--package",
        "@vue/language-server",
        "vue-language-server",
        "--stdio"
      ]
    },
    "svelte": {
      "command": [
        "bunx",
        "--package",
        "svelte-language-server",
        "svelteserver",
        "--stdio"
      ]
    },
    "astro": {
      "command": [
        "bunx",
        "--package",
        "@astrojs/language-server",
        "astro-ls",
        "--stdio"
      ]
    },
    "pyright": {
      "command": [
        "uvx",
        "--from",
        "basedpyright",
        "basedpyright-langserver",
        "--stdio"
      ]
    },
    "ruff": {
      "command": [
        "uvx",
        "--from",
        "ruff",
        "ruff",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  },
  "plugin": [
    "oh-my-opencode"
  ]
}
