{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "mcp": {
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true
    },
    "duckduckgo": {
      "type": "local",
      "command": [
        "uvx",
        "duckduckgo-mcp-server@latest"
      ],
      "enabled": true
    },
    "edgeone-pages": {
      "type": "local",
      "command": [
        "bunx",
        "edgeone-pages-mcp-fullstack@latest"
      ],
      "enabled": true
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "beads": {
      "type": "local",
      "command": [
        "uvx",
        "beads-mcp@latest"
      ],
      "enabled": true
    }
  },
  "lsp": {
    "typescript": {
      "command": [
        "bunx",
        "typescript-language-server@latest",
        "--stdio"
      ]
    },
    "vue": {
      "command": [
        "bunx",
        "@vue/language-server@latest",
        "--stdio"
      ]
    },
    "biome": {
      "command": [
        "bunx",
        "@biomejs/biome@latest",
        "lsp-proxy",
        "--stdio"
      ]
    },
    "svelte": {
      "command": [
        "bunx",
        "svelte-language-server@latest",
        "--stdio"
      ]
    },
    "astro": {
      "command": [
        "bunx",
        "@astrojs/language-server@latest",
        "--stdio"
      ]
    },
    "yaml-ls": {
      "command": [
        "bunx",
        "yaml-language-server@latest",
        "--stdio"
      ]
    },
    "php intelephense": {
      "command": [
        "bunx",
        "intelephense@latest",
        "--stdio"
      ]
    },
    "bash": {
      "command": [
        "bunx",
        "bash-language-server@latest",
        "start"
      ]
    },
    "dockerfile": {
      "command": [
        "bunx",
        "dockerfile-language-server-nodejs@latest",
        "--stdio"
      ]
    },
    "pyright": {
      "command": [
        "uvx",
        "basedpyright@latest",
        "--stdio"
      ]
    },
    "ty": {
      "command": [
        "uvx",
        "ty@latest",
        "server"
      ]
    },
    "oxlint": {
      "command": [
        "bunx",
        "oxlint@latest",
        "--lsp"
      ]
    },
    "prisma": {
      "command": [
        "bunx",
        "@prisma/language-server@latest",
        "--stdio"
      ]
    },
    "clangd": {
      "command": [
        "bunx",
        "clangd@latest",
        "--background-index",
        "--clang-tidy"
      ]
    }
  },
  "formatter": {
    "prettier": {
      "command": [
        "bunx",
        "prettier@latest",
        "--write",
        "$FILE"
      ]
    },
    "biome": {
      "command": [
        "bunx",
        "@biomejs/biome@latest",
        "format",
        "--write",
        "$FILE"
      ]
    },
    "oxfmt": {
      "command": [
        "bunx",
        "oxfmt@latest",
        "$FILE"
      ]
    },
    "ruff": {
      "command": [
        "uvx",
        "ruff@latest",
        "format",
        "$FILE"
      ]
    },
    "air": {
      "command": [
        "uvx",
        "--from",
        "air-formatter@latest",
        "air",
        "format",
        "$FILE"
      ]
    },
    "ktlint": {
      "command": [
        "bunx",
        "@naturalcycles/ktlint@latest",
        "-F",
        "$FILE"
      ]
    },
    "clang-format": {
      "command": [
        "bunx",
        "@wasm-fmt/clang-format@latest",
        "-i",
        "$FILE"
      ]
    }
  }
}