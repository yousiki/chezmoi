# Core interactive shell behavior that should exist before completions and tools.
setopt auto_cd
setopt auto_menu
setopt auto_pushd
setopt complete_in_word
setopt extended_glob
setopt interactive_comments
setopt no_beep
setopt prompt_subst
setopt pushd_ignore_dups
setopt pushdminus

WORDCHARS='*?_-.[]~=&;!#$%^(){}<>'
