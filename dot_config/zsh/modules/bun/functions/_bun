#compdef bun

local cache_dir cache_file

if ! command -v bun >/dev/null 2>&1; then
  return 1
fi

cache_dir="${ZSH_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/zsh}/completion"
cache_file="${cache_dir}/_bun"

mkdir -p "$cache_dir"

if [[ ! -s "$cache_file" || "$cache_file" -ot "${commands[bun]}" ]]; then
  command bun completions zsh >| "$cache_file" 2>/dev/null || return 1
fi

[[ -s "$cache_file" ]] || return 1

unfunction _bun 2>/dev/null || :
source "$cache_file"

_bun "$@"
