#!/usr/bin/env zsh

# Interactive configuration lives here. Login-only environment belongs in ~/.zprofile.
case $- in
  *i*) ;;
  *) return ;;
esac

: "${XDG_CONFIG_HOME:=$HOME/.config}"
export ZSH_CONFIG_DIR="${XDG_CONFIG_HOME}/zsh"

typeset -a zsh_config_files=(
  "$ZSH_CONFIG_DIR/10-base.zsh"
  "$ZSH_CONFIG_DIR/20-zim.zsh"
  "$ZSH_CONFIG_DIR/30-local.zsh"
)

for config_file in $zsh_config_files; do
  [[ -r "$config_file" ]] && source "$config_file"
done
